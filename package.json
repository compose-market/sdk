{
  "name": "@compose-market/sdk",
  "version": "0.6.98",
  "description": "Official Compose.Market SDK: Compose Keys, x402 facilitator, multi-provider model catalog, native streaming inference with typed receipts, unified tool-call events, agent + workflow runtime streams, live session events, and wallet-scoped persistence.",
  "keywords": [
    "compose",
    "compose-market",
    "x402",
    "x402-v2",
    "facilitator",
    "inference",
    "manowar",
    "agentic-economy",
    "decentralized-inference",
    "a2a"
  ],
  "homepage": "https://github.com/compose-market/sdk#readme",
  "bugs": {
    "url": "https://github.com/compose-market/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/compose-market/sdk.git"
  },
  "license": "MIT",
  "author": "Compose.Market",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./inference": {
      "types": "./generated/inference/esm/index.d.ts",
      "import": "./generated/inference/esm/index.js",
      "default": "./generated/inference/esm/index.js"
    },
    "./inference/models": {
      "types": "./generated/inference/esm/sdk/models.d.ts",
      "import": "./generated/inference/esm/sdk/models.js",
      "default": "./generated/inference/esm/sdk/models.js"
    },
    "./inference/modality": {
      "types": "./generated/inference/esm/sdk/modality.d.ts",
      "import": "./generated/inference/esm/sdk/modality.js",
      "default": "./generated/inference/esm/sdk/modality.js"
    },
    "./inference/schemas": {
      "types": "./generated/inference/esm/models/index.d.ts",
      "import": "./generated/inference/esm/models/index.js",
      "default": "./generated/inference/esm/models/index.js"
    },
    "./inference/operations": {
      "types": "./generated/inference/esm/models/operations/index.d.ts",
      "import": "./generated/inference/esm/models/operations/index.js",
      "default": "./generated/inference/esm/models/operations/index.js"
    },
    "./x402": {
      "types": "./generated/x402/esm/index.d.ts",
      "import": "./generated/x402/esm/index.js",
      "default": "./generated/x402/esm/index.js"
    },
    "./x402/facilitator": {
      "types": "./generated/x402/esm/sdk/x402.d.ts",
      "import": "./generated/x402/esm/sdk/x402.js",
      "default": "./generated/x402/esm/sdk/x402.js"
    },
    "./x402/keys": {
      "types": "./generated/x402/esm/sdk/compose-keys.d.ts",
      "import": "./generated/x402/esm/sdk/compose-keys.js",
      "default": "./generated/x402/esm/sdk/compose-keys.js"
    },
    "./x402/session": {
      "types": "./generated/x402/esm/sdk/compose-keys.d.ts",
      "import": "./generated/x402/esm/sdk/compose-keys.js",
      "default": "./generated/x402/esm/sdk/compose-keys.js"
    },
    "./x402/payments": {
      "types": "./generated/x402/esm/sdk/payments.d.ts",
      "import": "./generated/x402/esm/sdk/payments.js",
      "default": "./generated/x402/esm/sdk/payments.js"
    },
    "./x402/feedback": {
      "types": "./generated/x402/esm/sdk/feedback.d.ts",
      "import": "./generated/x402/esm/sdk/feedback.js",
      "default": "./generated/x402/esm/sdk/feedback.js"
    },
    "./x402/schemas": {
      "types": "./generated/x402/esm/models/index.d.ts",
      "import": "./generated/x402/esm/models/index.js",
      "default": "./generated/x402/esm/models/index.js"
    },
    "./x402/operations": {
      "types": "./generated/x402/esm/models/operations/index.d.ts",
      "import": "./generated/x402/esm/models/operations/index.js",
      "default": "./generated/x402/esm/models/operations/index.js"
    },
    "./memory": {
      "types": "./generated/memory/esm/index.d.ts",
      "import": "./generated/memory/esm/index.js",
      "default": "./generated/memory/esm/index.js"
    },
    "./memory/framework": {
      "types": "./generated/memory/esm/sdk/memory.d.ts",
      "import": "./generated/memory/esm/sdk/memory.js",
      "default": "./generated/memory/esm/sdk/memory.js"
    },
    "./memory/schemas": {
      "types": "./generated/memory/esm/models/index.d.ts",
      "import": "./generated/memory/esm/models/index.js",
      "default": "./generated/memory/esm/models/index.js"
    },
    "./memory/operations": {
      "types": "./generated/memory/esm/models/operations/index.d.ts",
      "import": "./generated/memory/esm/models/operations/index.js",
      "default": "./generated/memory/esm/models/operations/index.js"
    },
    "./manowar": {
      "types": "./generated/manowar/esm/index.d.ts",
      "import": "./generated/manowar/esm/index.js",
      "default": "./generated/manowar/esm/index.js"
    },
    "./manowar/agent": {
      "types": "./generated/manowar/esm/sdk/agents.d.ts",
      "import": "./generated/manowar/esm/sdk/agents.js",
      "default": "./generated/manowar/esm/sdk/agents.js"
    },
    "./manowar/workflow": {
      "types": "./generated/manowar/esm/sdk/workflows.d.ts",
      "import": "./generated/manowar/esm/sdk/workflows.js",
      "default": "./generated/manowar/esm/sdk/workflows.js"
    },
    "./manowar/connectors": {
      "types": "./generated/manowar/esm/sdk/connectors.d.ts",
      "import": "./generated/manowar/esm/sdk/connectors.js",
      "default": "./generated/manowar/esm/sdk/connectors.js"
    },
    "./manowar/workspace": {
      "types": "./generated/manowar/esm/sdk/workspace.d.ts",
      "import": "./generated/manowar/esm/sdk/workspace.js",
      "default": "./generated/manowar/esm/sdk/workspace.js"
    },
    "./manowar/mesh": {
      "types": "./generated/manowar/esm/sdk/mesh.d.ts",
      "import": "./generated/manowar/esm/sdk/mesh.js",
      "default": "./generated/manowar/esm/sdk/mesh.js"
    },
    "./manowar/schemas": {
      "types": "./generated/manowar/esm/models/index.d.ts",
      "import": "./generated/manowar/esm/models/index.js",
      "default": "./generated/manowar/esm/models/index.js"
    },
    "./manowar/operations": {
      "types": "./generated/manowar/esm/models/operations/index.d.ts",
      "import": "./generated/manowar/esm/models/operations/index.js",
      "default": "./generated/manowar/esm/models/operations/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "generated/x402/esm",
    "generated/x402/src",
    "generated/x402/package.json",
    "generated/x402/README.md",
    "generated/inference/esm",
    "generated/inference/src",
    "generated/inference/package.json",
    "generated/inference/README.md",
    "generated/memory/esm",
    "generated/memory/src",
    "generated/memory/package.json",
    "generated/memory/README.md",
    "generated/manowar/esm",
    "generated/manowar/src",
    "generated/manowar/package.json",
    "generated/manowar/README.md",
    "specs",
    ".speakeasy/inference.arazzo.yaml",
    ".speakeasy/tests.arazzo.yaml",
    ".speakeasy/memory.arazzo.yaml",
    ".speakeasy/a2a.arazzo.yaml",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "sync-version": "node scripts/sync-version.mjs",
    "speakeasy:watch": "npm run sync-version && speakeasy run --watch --target all --output console --skip-versioning",
    "build:generated:x402": "rm -rf generated/x402/esm && npm --prefix generated/x402 install --ignore-scripts && npm --prefix generated/x402 run build",
    "build:generated:inference": "rm -rf generated/inference/esm && npm --prefix generated/inference install --ignore-scripts && npm --prefix generated/inference run build",
    "build:generated:memory": "rm -rf generated/memory/esm && npm --prefix generated/memory install --ignore-scripts && npm --prefix generated/memory run build",
    "build:generated:manowar": "rm -rf generated/manowar/esm && npm --prefix generated/manowar install --ignore-scripts && npm --prefix generated/manowar run build",
    "build:generated": "npm run build:generated:x402 && npm run build:generated:inference && npm run build:generated:memory && npm run build:generated:manowar",
    "build": "npm run sync-version && npm run clean && tsc -p tsconfig.json && npm run build:generated",
    "test": "npm run sync-version && node --import tsx --test tests/sdk.unit.test.ts tests/sdk.streaming.test.ts tests/sdk.contract.test.ts tests/sdk.session-events.test.ts tests/sdk.events.test.ts tests/sdk.runtime-streams.test.ts",
    "test:build": "npm run build && npm test",
    "obs:eval": "tsx tests/e2e/eval-recall.ts",
    "obs:retention": "tsx tests/e2e/memory-d-validation.ts",
    "typecheck": "npm run sync-version && tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run test:build"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@x402/core": "^2.13.0",
    "@x402/evm": "^2.13.0",
    "viem": "^2.51.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}