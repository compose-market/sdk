{
  "name": "@compose-market/sdk",
  "version": "0.5.0",
  "description": "Official Compose.Market SDK: Compose Keys, x402 facilitator, 45k+ model catalog, OpenAI-shaped streaming inference with typed receipts, unified tool-call events, agent + workflow runtime streams, live session events, and wallet-scoped persistence.",
  "keywords": [
    "compose",
    "compose-market",
    "x402",
    "x402-v2",
    "facilitator",
    "inference",
    "openai-compatible",
    "agentic-economy",
    "decentralized-inference",
    "a2a"
  ],
  "homepage": "https://github.com/compose-market/sdk#readme",
  "bugs": {
    "url": "https://github.com/compose-market/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/compose-market/sdk.git"
  },
  "license": "MIT",
  "author": "Compose.Market",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./inference": {
      "types": "./generated/inference/esm/index.d.ts",
      "import": "./generated/inference/esm/index.js",
      "default": "./generated/inference/esm/index.js"
    },
    "./inference/models": {
      "types": "./generated/inference/esm/sdk/models.d.ts",
      "import": "./generated/inference/esm/sdk/models.js",
      "default": "./generated/inference/esm/sdk/models.js"
    },
    "./inference/modality": {
      "types": "./generated/inference/esm/sdk/modality.d.ts",
      "import": "./generated/inference/esm/sdk/modality.js",
      "default": "./generated/inference/esm/sdk/modality.js"
    },
    "./inference/schemas": {
      "types": "./generated/inference/esm/models/index.d.ts",
      "import": "./generated/inference/esm/models/index.js",
      "default": "./generated/inference/esm/models/index.js"
    },
    "./inference/operations": {
      "types": "./generated/inference/esm/models/operations/index.d.ts",
      "import": "./generated/inference/esm/models/operations/index.js",
      "default": "./generated/inference/esm/models/operations/index.js"
    },
    "./x402": {
      "types": "./generated/x402/esm/index.d.ts",
      "import": "./generated/x402/esm/index.js",
      "default": "./generated/x402/esm/index.js"
    },
    "./x402/facilitator": {
      "types": "./generated/x402/esm/sdk/x402.d.ts",
      "import": "./generated/x402/esm/sdk/x402.js",
      "default": "./generated/x402/esm/sdk/x402.js"
    },
    "./x402/keys": {
      "types": "./generated/x402/esm/sdk/compose-keys.d.ts",
      "import": "./generated/x402/esm/sdk/compose-keys.js",
      "default": "./generated/x402/esm/sdk/compose-keys.js"
    },
    "./x402/session": {
      "types": "./generated/x402/esm/sdk/compose-keys.d.ts",
      "import": "./generated/x402/esm/sdk/compose-keys.js",
      "default": "./generated/x402/esm/sdk/compose-keys.js"
    },
    "./x402/payments": {
      "types": "./generated/x402/esm/sdk/payments.d.ts",
      "import": "./generated/x402/esm/sdk/payments.js",
      "default": "./generated/x402/esm/sdk/payments.js"
    },
    "./agentic": {
      "types": "./generated/agentic/esm/index.d.ts",
      "import": "./generated/agentic/esm/index.js",
      "default": "./generated/agentic/esm/index.js"
    },
    "./agentic/agent": {
      "types": "./generated/agentic/esm/sdk/agents.d.ts",
      "import": "./generated/agentic/esm/sdk/agents.js",
      "default": "./generated/agentic/esm/sdk/agents.js"
    },
    "./agentic/workflow": {
      "types": "./generated/agentic/esm/sdk/workflows.d.ts",
      "import": "./generated/agentic/esm/sdk/workflows.js",
      "default": "./generated/agentic/esm/sdk/workflows.js"
    },
    "./agentic/memory": {
      "types": "./generated/agentic/esm/sdk/memory.d.ts",
      "import": "./generated/agentic/esm/sdk/memory.js",
      "default": "./generated/agentic/esm/sdk/memory.js"
    },
    "./agentic/tools": {
      "types": "./generated/agentic/esm/sdk/tools.d.ts",
      "import": "./generated/agentic/esm/sdk/tools.js",
      "default": "./generated/agentic/esm/sdk/tools.js"
    },
    "./agentic/workspace": {
      "types": "./generated/agentic/esm/sdk/workspace.d.ts",
      "import": "./generated/agentic/esm/sdk/workspace.js",
      "default": "./generated/agentic/esm/sdk/workspace.js"
    },
    "./agentic/mesh": {
      "types": "./generated/agentic/esm/sdk/mesh.d.ts",
      "import": "./generated/agentic/esm/sdk/mesh.js",
      "default": "./generated/agentic/esm/sdk/mesh.js"
    },
    "./agentic/schemas": {
      "types": "./generated/agentic/esm/models/index.d.ts",
      "import": "./generated/agentic/esm/models/index.js",
      "default": "./generated/agentic/esm/models/index.js"
    },
    "./agentic/operations": {
      "types": "./generated/agentic/esm/models/operations/index.d.ts",
      "import": "./generated/agentic/esm/models/operations/index.js",
      "default": "./generated/agentic/esm/models/operations/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "generated/x402/esm",
    "generated/x402/src",
    "generated/x402/package.json",
    "generated/x402/README.md",
    "generated/inference/esm",
    "generated/inference/src",
    "generated/inference/package.json",
    "generated/inference/README.md",
    "generated/agentic/esm",
    "generated/agentic/src",
    "generated/agentic/package.json",
    "generated/agentic/README.md",
    "specs",
    ".speakeasy/tests.arazzo.yaml",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "sync-version": "node scripts/sync-version.mjs",
    "build:generated:x402": "npm --prefix generated/x402 install --ignore-scripts && npm --prefix generated/x402 run build",
    "build:generated:inference": "npm --prefix generated/inference install --ignore-scripts && npm --prefix generated/inference run build",
    "build:generated:agentic": "npm --prefix generated/agentic install --ignore-scripts && npm --prefix generated/agentic run build",
    "build:generated": "npm run build:generated:x402 && npm run build:generated:inference && npm run build:generated:agentic",
    "build": "npm run sync-version && npm run clean && tsc -p tsconfig.json && npm run build:generated",
    "test": "npm run sync-version && node --import tsx --test tests/sdk.unit.test.ts tests/sdk.streaming.test.ts tests/sdk.contract.test.ts tests/sdk.session-events.test.ts tests/sdk.events.test.ts tests/sdk.runtime-streams.test.ts",
    "test:build": "npm run build && npm test",
    "typecheck": "npm run sync-version && tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run test:build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
